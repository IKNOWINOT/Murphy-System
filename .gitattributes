# Murphy System - Git Attributes
# Ensures consistent behavior across Windows, macOS, and Linux.

# ---- Line-ending normalisation ----
# Check out as native line endings, commit as LF.
* text=auto

# Force LF for all source files regardless of platform.
*.py     text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.bat    text eol=crlf

# ---- Binary files (do not diff / do not normalise) ----
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.whl    binary
*.sqlite binary
*.db     binary

# ---- Linguist overrides for GitHub stats ----
# Mark vendored / generated paths so they don't skew language stats.
Murphy[[:space:]]System/bots/engineering_bot/internal/** linguist-vendored
Murphy[[:space:]]System/bots/ghost_controller_bot/internal/** linguist-vendored
