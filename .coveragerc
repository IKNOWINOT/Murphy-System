[run]
branch = true
# Class S Roadmap — Item 5: track coverage across the whole src/ tree, not just
# the two seed modules. Existing focused modules remain explicitly listed so
# their per-module coverage can still be inspected in reports.
source =
    src
    rosetta_subsystem_wiring
    startup_feature_summary
omit =
    src/tests/*
    src/*_test.py
    src/**/tests/*
    src/**/test_*.py
    src/**/*_test.py

[report]
show_missing = true
# Class S Roadmap — Item 5: ratchet floor. Start at 0% so expanding `source` to
# the whole `src/` tree does not block existing CI. Raise this floor each
# quarter as targeted tests land for low-coverage subsystems
# (integration connectors, LCM engine, platform self-modification).
# Target trajectory: Q1=20, Q2=40, Q3=60, Q4=80.
fail_under = 0
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__
    @abstractmethod
    if TYPE_CHECKING:
