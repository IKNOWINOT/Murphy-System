# org.murphy.System.service — D-Bus service activation file
# © 2020 Inoni Limited Liability Company | Creator: Corey Post | License: BSL 1.1
#
# Installed to: /usr/share/dbus-1/system-services/org.murphy.System.service
#
# When a client first calls a method on org.murphy.System and the service
# is not yet running, dbus-daemon will auto-activate it via this file.

[D-BUS Service]
Name=org.murphy.System
Exec=/usr/lib/murphy/murphy-dbus-service
User=murphy
SystemdService=murphy-dbus.service
