#!/bin/sh
# murphy-net-register — Register network interfaces with Murphy Event Backbone
# © 2020 Inoni Limited Liability Company, Creator: Corey Post
# License: BSL 1.1
#
# Called by udev when a new network interface is added.

set -e

MURPHY_EVENT_DEV="/dev/murphy-event"
MURPHY_API="http://localhost:8000/api/system/net-register"
TAG="murphy-net-register"

# Escape a value for safe embedding in a JSON string
json_esc() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }

IFACE=$(json_esc "${INTERFACE:-unknown}")
DEV_NAME=$(json_esc "${DEVNAME:-${INTERFACE:-unknown}}")
DEV_TYPE=$(json_esc "${ID_NET_DRIVER:-unknown}")
MAC_ADDR=$(json_esc "${ID_NET_NAME_MAC:-unknown}")

json_payload=$(cat <<EOF
{"event":"net_register","interface":"${IFACE}","devname":"${DEV_NAME}","driver":"${DEV_TYPE}","mac":"${MAC_ADDR}","timestamp":"$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
EOF
)

if [ -w "$MURPHY_EVENT_DEV" ]; then
    echo "$json_payload" > "$MURPHY_EVENT_DEV" 2>/dev/null && \
        logger -t "$TAG" "Registered interface ${IFACE} via ${MURPHY_EVENT_DEV}" && \
        exit 0
fi

if command -v curl >/dev/null 2>&1; then
    curl -s -m 5 -X POST \
        -H "Content-Type: application/json" \
        -d "$json_payload" \
        "$MURPHY_API" >/dev/null 2>&1 && \
        logger -t "$TAG" "Registered interface ${IFACE} via HTTP API" && \
        exit 0
fi

logger -t "$TAG" -p user.warning \
    "Failed to register interface ${IFACE}"
exit 0
