#!/usr/sbin/nft -f
# SPDX-License-Identifier: BSL-1.1
# © 2020 Inoni Limited Liability Company — Creator: Corey Post
#
# Murphy System — nftables network-security ruleset
# Loaded by murphy-nftables.service at boot.

flush ruleset

table inet murphy_security {

    # ── Sets ───────────────────────────────────────────────────
    set murphy_managed_ports {
        type inet_service
        elements = { 8000, 8448, 5354 }
        comment "Ports managed by Murphy System"
    }

    set llm_provider_nets {
        type ipv4_addr
        flags interval
        comment "Known AI/LLM API provider IP ranges (rate-limited)"
        elements = {
            # OpenAI
            13.107.238.0/24,
            # Anthropic (example)
            104.18.0.0/16
        }
    }

    set swarm_agent_addrs {
        type ipv4_addr
        flags interval
        comment "Swarm agent loopback/namespace addresses"
        elements = {
            127.0.100.0/24
        }
    }

    # Mark value for Murphy-managed traffic
    # 0x4d55 = "MU" in ASCII
    set murphy_mark {
        type mark
        elements = { 0x00004d55 }
    }

    # ── Chain: OUTPUT (mark + rate-limit outbound) ─────────────
    chain murphy_output {
        type filter hook output priority mangle; policy accept;

        # Mark packets destined for Murphy-managed ports
        tcp dport @murphy_managed_ports meta mark set 0x00004d55 \
            comment "Tag Murphy-managed outbound traffic"

        udp dport @murphy_managed_ports meta mark set 0x00004d55 \
            comment "Tag Murphy-managed outbound UDP traffic"

        # Rate-limit outbound HTTPS to known LLM provider IPs
        # Prevents runaway token spend from misconfigured agents
        ip daddr @llm_provider_nets tcp dport 443 \
            limit rate over 50/second burst 100 packets \
            drop \
            comment "Rate-limit LLM API traffic to prevent cost overrun"

        # Always allow localhost
        oifname "lo" accept comment "Allow all loopback output"
    }

    # ── Chain: FORWARD (swarm agent isolation) ─────────────────
    chain murphy_swarm_isolation {
        type filter hook forward priority 0; policy drop;

        # Agents are isolated by default (policy drop).

        # Allow established/related return traffic
        ct state established,related accept \
            comment "Allow return traffic for established connections"

        # Allow traffic from high-confidence agents (mark >= 0x70 set by
        # the Murphy confidence daemon via SO_MARK on agent sockets).
        meta mark 0x00004d55 accept \
            comment "Allow forwarded traffic from Murphy-marked (confident) agents"

        # Log and drop everything else from swarm agent addresses
        ip saddr @swarm_agent_addrs \
            log prefix "[murphy-swarm-drop] " group 1 \
            drop \
            comment "Log and drop low-confidence swarm agent traffic"
    }

    # ── Chain: INPUT (protect Murphy services) ─────────────────
    chain murphy_input {
        type filter hook input priority 0; policy accept;

        # Accept established / related
        ct state established,related accept \
            comment "Allow established and related inbound"

        # Accept Murphy API on port 8000 from localhost only
        iifname "lo" tcp dport 8000 accept \
            comment "Murphy API — localhost only"

        # Accept Matrix federation port 8448 (may come from network)
        tcp dport 8448 accept \
            comment "Matrix federation port"

        # Accept Murphy DNS resolver on 5354 from localhost
        iifname "lo" udp dport 5354 accept \
            comment "Murphy DNS resolver — localhost only"

        # Drop unsolicited inbound to other Murphy ports from non-local
        iifname != "lo" tcp dport @murphy_managed_ports \
            drop \
            comment "Drop non-local inbound to Murphy-managed ports"

        iifname != "lo" udp dport @murphy_managed_ports \
            drop \
            comment "Drop non-local inbound to Murphy-managed UDP ports"
    }
}
