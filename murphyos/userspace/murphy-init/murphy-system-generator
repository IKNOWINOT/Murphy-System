#!/bin/bash
# murphy-system-generator — systemd generator for Murphy engine services
# © 2020 Inoni Limited Liability Company | Creator: Corey Post | License: BSL 1.1
#
# Installed to: /usr/lib/systemd/system-generators/murphy-system-generator
#
# At early boot systemd executes generators before loading units.
# This generator reads /murphy/engines/*.conf to discover which Murphy
# engine modules are configured and creates corresponding service
# drop-ins or symlinks so they start automatically.
#
# Arguments (supplied by systemd):
#   $1 — normal unit directory   (e.g. /run/systemd/generator)
#   $2 — early unit directory    (usually empty)
#   $3 — late unit directory     (usually empty)
#
# See systemd.generator(7) for the full contract.

set -euo pipefail

NORMAL_DIR="${1:?missing normal unit directory}"
ENGINE_CONF_DIR="/murphy/engines"
MURPHY_SERVICE="murphy-system.service"

# Bail out silently when there is nothing to generate.
if [ ! -d "$ENGINE_CONF_DIR" ]; then
    exit 0
fi

# Ensure the target wants-directory exists.
mkdir -p "${NORMAL_DIR}/multi-user.target.wants"
mkdir -p "${NORMAL_DIR}/${MURPHY_SERVICE}.wants"

# Iterate over engine configuration files.
for conf in "${ENGINE_CONF_DIR}"/*.conf; do
    [ -e "$conf" ] || continue          # guard against empty glob

    engine_name=""
    engine_enabled=""
    engine_args=""

    # Parse simple KEY=VALUE pairs from each engine config.
    while IFS='=' read -r key value; do
        key="${key## }"                  # trim leading whitespace
        key="${key%% }"                  # trim trailing whitespace
        value="${value## }"
        value="${value%% }"
        case "$key" in
            name)    engine_name="$value"    ;;
            enabled) engine_enabled="$value" ;;
            args)    engine_args="$value"    ;;
        esac
    done < "$conf"

    # Skip disabled or unnamed engines.
    if [ -z "$engine_name" ] || [ "$engine_enabled" != "true" ]; then
        continue
    fi

    service_name="murphy-engine-${engine_name}.service"

    # Generate a transient service unit for this engine.
    cat > "${NORMAL_DIR}/${service_name}" <<EOF
# Auto-generated by murphy-system-generator — do not edit.
[Unit]
Description=Murphy Engine — ${engine_name}
After=${MURPHY_SERVICE}
BindsTo=${MURPHY_SERVICE}
PartOf=${MURPHY_SERVICE}

[Service]
Type=simple
User=murphy
Group=murphy
ExecStart=/usr/bin/python3 -m murphy.engines.${engine_name} ${engine_args}
Environment=PYTHONPATH=/murphy/runtime
Environment=MURPHY_ENV=production
Environment=MURPHY_SOCKET=/run/murphy/murphy.sock
Restart=on-failure
RestartSec=10

# Security hardening (inherits most from parent slice)
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/murphy/persistence /murphy/logs /murphy/telemetry
ReadOnlyPaths=/murphy/runtime /murphy/engines
EOF

    # Wire into multi-user.target and murphy-system.service.
    ln -sf "${NORMAL_DIR}/${service_name}" \
        "${NORMAL_DIR}/multi-user.target.wants/${service_name}"
    ln -sf "${NORMAL_DIR}/${service_name}" \
        "${NORMAL_DIR}/${MURPHY_SERVICE}.wants/${service_name}"
done

exit 0
