#!/bin/bash
# murphy-watchdog — Self-Healing health-check loop
# © 2020 Inoni Limited Liability Company | Creator: Corey Post | License: BSL 1.1
#
# Installed to: /usr/lib/murphy/murphy-watchdog
#
# Polls the Murphy API health endpoint every 10 seconds.
# After 3 consecutive failures the watchdog restarts murphy-system.service
# and emits a self-healing event via the Murphy event device.

set -euo pipefail

HEALTH_URL="http://localhost:8000/api/health"
CHECK_INTERVAL=10
FAIL_THRESHOLD=3
SERVICE_NAME="murphy-system.service"
EVENT_DEVICE="/dev/murphy-event"

fail_count=0

log() {
    logger -t murphy-watchdog -p "daemon.${1}" -- "${2}"
}

emit_self_healing_event() {
    local reason="$1"
    local timestamp
    timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local payload="{\"event\":\"self-healing\",\"reason\":\"${reason}\",\"ts\":\"${timestamp}\"}"

    if [ -e "$EVENT_DEVICE" ]; then
        echo "$payload" > "$EVENT_DEVICE" 2>/dev/null || true
    fi

    log "warning" "Self-healing event: ${reason}"
}

restart_murphy() {
    log "err" "Health check failed ${FAIL_THRESHOLD} times — restarting ${SERVICE_NAME}"
    emit_self_healing_event "health-check-failure-restart"

    systemctl restart "$SERVICE_NAME" 2>/dev/null || \
        log "crit" "Failed to restart ${SERVICE_NAME}"
}

log "info" "Murphy watchdog started (interval=${CHECK_INTERVAL}s, threshold=${FAIL_THRESHOLD})"

while true; do
    if http_code="$(curl -sf -o /dev/null -w '%{http_code}' --max-time 5 "$HEALTH_URL" 2>/dev/null)"; then
        if [ "$http_code" = "200" ]; then
            if [ "$fail_count" -gt 0 ]; then
                log "info" "Health restored after ${fail_count} failure(s)"
            fi
            fail_count=0
        else
            fail_count=$((fail_count + 1))
            log "warning" "Health check returned HTTP ${http_code} (${fail_count}/${FAIL_THRESHOLD})"
        fi
    else
        fail_count=$((fail_count + 1))
        log "warning" "Health check unreachable (${fail_count}/${FAIL_THRESHOLD})"
    fi

    if [ "$fail_count" -ge "$FAIL_THRESHOLD" ]; then
        restart_murphy
        fail_count=0
        # Give the service time to come back up before re-checking.
        sleep 30
        continue
    fi

    sleep "$CHECK_INTERVAL"
done
