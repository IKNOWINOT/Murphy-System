<schemalist gettext-domain="murphy-system">
  <schema id="org.murphy.system" path="/org/murphy/system/">
    <key name="api-url" type="s">
      <default>'http://localhost:8000'</default>
      <summary>Murphy API URL</summary>
      <description>Base URL of the Murphy API server</description>
    </key>
    <key name="poll-interval" type="i">
      <default>5</default>
      <summary>Poll interval</summary>
      <description>Seconds between confidence score refreshes</description>
      <range min="1" max="300"/>
    </key>
    <key name="show-notifications" type="b">
      <default>true</default>
      <summary>Show notifications</summary>
      <description>Display HITL approval and Forge progress notifications</description>
    </key>
    <key name="show-pqc-indicator" type="b">
      <default>true</default>
      <summary>Show PQC indicator</summary>
      <description>Display the post-quantum cryptography lock icon in the panel</description>
    </key>
    <key name="brand-accent-color" type="s">
      <default>'#00D4AA'</default>
      <summary>Brand accent colour</summary>
      <description>Primary Murphy brand accent colour (teal). Used by indicator and notifications.</description>
    </key>
  </schema>
</schemalist>
