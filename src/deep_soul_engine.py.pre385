    sid = data.get("id") or str(uuid.uuid4())
    with _db() as c:
        c.execute("""INSERT OR REPLACE INTO sops
            (id,title,domain,role,steps,regulatory_refs,reference_books,follow_up_protocol,created_at)
            VALUES (?,?,?,?,?,?,?,?,?)""", (
            sid, data.get("title",""), data.get("domain",""), data.get("role",""),
            json.dumps(data.get("steps",[])),
            json.dumps(data.get("regulatory_refs",[])),
            json.dumps(data.get("reference_books",[])),
            json.dumps(data.get("follow_up_protocol",{})),
            datetime.now(timezone.utc).isoformat()))
    return sid

