"""
PATCH-384: Deep Soul Engine
============================
Expands agent souls from 95 words to 3,000-7,000 words of real context:

LAYERS:
  L0  — Identity card (~50 tokens): who, what role, what company, what contract
  L1  — Critical facts (~200 tokens): top KPIs, OCEAN personality, current projects
  L2  — Full employment contract (~600 tokens): duties, pipeline touchpoints, SOPs,
        escalation paths, HITL gates, regulatory references
  L3  — Deep knowledge (~2000 tokens): training materials, reference books/standards,
        "For Dummies" domain knowledge, project schedules vs ROI calendar,
        daily input filters, follow-up protocols
  L4  — Live context (~500 tokens, refreshed per-dispatch): Gmail thread summaries,
        active project status, unresolved follow-ups, today's priority queue

ENTITY GRAPH:
  Person → works_for → Company
  Person → assigned_to → Project
  Project → under → Contract
  Contract → has_sop → SOP
  SOP → references → RegulatoryBook
  Agent → shadows → Person
  Agent → has_contract → EmploymentContract
  Agent → trained_on → TrainingMaterial

GMAIL INTEGRATION:
  Murphy gets the same Gmail access I have (corey.gfc@gmail.com token).
  Agents can: read threads by label/project, send on behalf of role,
  monitor for replies, trigger follow-up SOPs on silence.
"""
from __future__ import annotations

import hashlib, json, os, re, sqlite3, uuid, logging
from dataclasses import dataclass, field, asdict
from datetime import datetime, timezone
from typing import Any, Dict, List, Optional, Tuple

logger = logging.getLogger("murphy.deep_soul")
DB_PATH = "/var/lib/murphy-production/entity_graph.db"


# ═══════════════════════════════════════════════════════════════
# DATABASE — entity graph schema
# ═══════════════════════════════════════════════════════════════

def _db() -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH, timeout=10)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.row_factory = sqlite3.Row
    return conn

def ensure_schema():
    with _db() as c:
        c.executescript("""
        -- Core entities
        CREATE TABLE IF NOT EXISTS persons (
            id TEXT PRIMARY KEY,
            full_name TEXT,
            email TEXT,
            phone TEXT,
            title TEXT,
            discipline TEXT,
            licenses TEXT,          -- JSON list: ["PE-FL-12345","CEM","LEED AP"]
            years_experience INTEGER,
            resume_text TEXT,       -- full resume, no limit
            references_text TEXT,   -- reference letters / names
            skills TEXT,            -- JSON list
            certifications TEXT,    -- JSON list
            created_at TEXT
        );
        CREATE TABLE IF NOT EXISTS companies (
            id TEXT PRIMARY KEY,
            name TEXT,
            industry TEXT,
            location TEXT,
            website TEXT,
            description TEXT,
            size_employees INTEGER,
            primary_contact_id TEXT,
            created_at TEXT
        );
        CREATE TABLE IF NOT EXISTS projects (
            id TEXT PRIMARY KEY,
            name TEXT,
            company_id TEXT,
            contract_id TEXT,
            status TEXT,            -- active|pending|complete|on-hold
            start_date TEXT,
            end_date TEXT,
            budget_usd REAL,
            description TEXT,
            milestones TEXT,        -- JSON list of {name, date, complete}
            roi_calendar TEXT,      -- JSON: monthly projected ROI vs actual
            daily_inputs TEXT,      -- JSON: what to check/log each day
            created_at TEXT
        );
        CREATE TABLE IF NOT EXISTS contracts (
            id TEXT PRIMARY KEY,
            project_id TEXT,
            company_id TEXT,
            contract_type TEXT,     -- fixed|T&M|retainer|lump-sum
            value_usd REAL,
            start_date TEXT,
            end_date TEXT,
            scope_text TEXT,        -- full scope of work
            deliverables TEXT,      -- JSON list
            payment_terms TEXT,
            penalties TEXT,
            status TEXT,            -- draft|active|complete|disputed
            created_at TEXT
        );
        -- Relationship graph (generic edge table)
        CREATE TABLE IF NOT EXISTS relationships (
            id TEXT PRIMARY KEY,
            from_type TEXT,         -- person|company|project|contract|agent
            from_id TEXT,
            rel_type TEXT,          -- works_for|assigned_to|owns|reports_to|shadows|manages
            to_type TEXT,
            to_id TEXT,
            metadata TEXT,          -- JSON: role, since, notes
            created_at TEXT
        );
        -- Agent employment contracts
        CREATE TABLE IF NOT EXISTS agent_contracts (
            id TEXT PRIMARY KEY,
            agent_id TEXT UNIQUE,
            agent_name TEXT,
            role_title TEXT,
            department TEXT,
            domain TEXT,
            management_layer TEXT,
            -- Employment terms
            duties_text TEXT,           -- full list of duties
            pipeline_touchpoints TEXT,  -- JSON: [{step, action, output, hands_to}]
            escalation_paths TEXT,      -- JSON: [{trigger, goes_to, sla_hours}]
            hitl_threshold REAL,
            -- Personality (OCEAN)
            ocean_json TEXT,
            persona_label TEXT,
            communication_style TEXT,
            decision_style TEXT,
            stress_response TEXT,
            -- KPIs
            kpis_json TEXT,
            -- Authority
            authorised_actions TEXT,    -- JSON list
            off_limits TEXT,            -- JSON list
            recalibration_triggers TEXT,-- JSON list
            created_at TEXT,
            updated_at TEXT
        );
        -- SOP library
        CREATE TABLE IF NOT EXISTS sops (
            id TEXT PRIMARY KEY,
            title TEXT,
            domain TEXT,
            role TEXT,              -- which role this SOP applies to
            steps TEXT,             -- JSON: [{step, action, decision_point, output, escalate_if}]
            regulatory_refs TEXT,   -- JSON: ["ASHRAE 90.1-2022 Sec 6.4", "NFPA 90A"]
            reference_books TEXT,   -- JSON: ["HVAC for Dummies", "ASHRAE Handbook Fundamentals"]
            follow_up_protocol TEXT,-- JSON: what to do if no response at 24h/48h/72h
            created_at TEXT
        );
        -- Training materials
        CREATE TABLE IF NOT EXISTS training_materials (
            id TEXT PRIMARY KEY,
            title TEXT,
            domain TEXT,
            level TEXT,             -- beginner|intermediate|advanced|regulatory
            content_text TEXT,      -- full training content, no limit
            source TEXT,            -- "ASHRAE Handbook", "For Dummies", "Murphy SOP"
            role_applicability TEXT,-- JSON: which roles this applies to
            created_at TEXT
        );
        -- Gmail thread index
        CREATE TABLE IF NOT EXISTS gmail_threads (
            id TEXT PRIMARY KEY,
            gmail_thread_id TEXT,
            gmail_message_id TEXT,
            subject TEXT,
            from_email TEXT,
            to_emails TEXT,
            project_id TEXT,
            contract_id TEXT,
            contact_id TEXT,
            summary TEXT,
            action_required TEXT,   -- what Murphy should do
            follow_up_due TEXT,     -- ISO date
            status TEXT,            -- open|replied|closed|escalated
            raw_snippet TEXT,
            created_at TEXT,
            updated_at TEXT
        );
        -- Daily priority queue
        CREATE TABLE IF NOT EXISTS daily_priorities (
            id TEXT PRIMARY KEY,
            date TEXT,
            agent_id TEXT,
            priority_order INTEGER,
            item_type TEXT,         -- email|project|contract|follow-up|task
            item_id TEXT,
            title TEXT,
            description TEXT,
            status TEXT,            -- pending|done|deferred
            created_at TEXT
        );
        """)
    logger.info("entity_graph schema ready")


# ═══════════════════════════════════════════════════════════════
# ENTITY CRUD
# ═══════════════════════════════════════════════════════════════

def upsert_person(data: Dict) -> str:
    pid = data.get("id") or str(uuid.uuid4())
    with _db() as c:
        c.execute("""INSERT OR REPLACE INTO persons
            (id,full_name,email,phone,title,discipline,licenses,years_experience,
             resume_text,references_text,skills,certifications,created_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)""", (
            pid, data.get("full_name",""), data.get("email",""), data.get("phone",""),
            data.get("title",""), data.get("discipline",""),
            json.dumps(data.get("licenses",[])), data.get("years_experience",0),
            data.get("resume_text",""), data.get("references_text",""),
            json.dumps(data.get("skills",[])), json.dumps(data.get("certifications",[])),
            datetime.now(timezone.utc).isoformat()))
    return pid

def upsert_company(data: Dict) -> str:
    cid = data.get("id") or str(uuid.uuid4())
    with _db() as c:
        c.execute("""INSERT OR REPLACE INTO companies
            (id,name,industry,location,website,description,size_employees,primary_contact_id,created_at)
            VALUES (?,?,?,?,?,?,?,?,?)""", (
            cid, data.get("name",""), data.get("industry",""), data.get("location",""),
            data.get("website",""), data.get("description",""), data.get("size_employees",0),
            data.get("primary_contact_id",""), datetime.now(timezone.utc).isoformat()))
    return cid

def upsert_project(data: Dict) -> str:
    pid = data.get("id") or str(uuid.uuid4())
    with _db() as c:
        c.execute("""INSERT OR REPLACE INTO projects
            (id,name,company_id,contract_id,status,start_date,end_date,budget_usd,
             description,milestones,roi_calendar,daily_inputs,created_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)""", (
            pid, data.get("name",""), data.get("company_id",""), data.get("contract_id",""),
            data.get("status","active"), data.get("start_date",""), data.get("end_date",""),
            data.get("budget_usd",0.0), data.get("description",""),
            json.dumps(data.get("milestones",[])),
            json.dumps(data.get("roi_calendar",{})),
            json.dumps(data.get("daily_inputs",[])),
            datetime.now(timezone.utc).isoformat()))
    return pid

def add_relationship(from_type:str, from_id:str, rel_type:str, to_type:str, to_id:str, metadata:Dict=None) -> str:
    rid = str(uuid.uuid4())
    with _db() as c:
        c.execute("""INSERT OR REPLACE INTO relationships
            (id,from_type,from_id,rel_type,to_type,to_id,metadata,created_at)
            VALUES (?,?,?,?,?,?,?,?)""", (
            rid, from_type, from_id, rel_type, to_type, to_id,
            json.dumps(metadata or {}), datetime.now(timezone.utc).isoformat()))
    return rid

