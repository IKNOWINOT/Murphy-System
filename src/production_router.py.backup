import os as _os_saas

@app.route('/api/saas/book', methods=['POST'])
def saas_book_335():
    """Book a discovery call for enterprise-candidate leads."""
    import sqlite3, uuid, json
    from datetime import datetime
    data = request.get_json() or {}
    sub_id = data.get('id') or ''
    slot_dt = data.get('slot_date') or ''
    slot_tm = data.get('slot_time') or ''
    notes = data.get('notes') or ''
    
    conn = sqlite3.connect("/var/lib/murphy-production/saas_subscribers.db")
    conn.row_factory = sqlite3.Row
    row = conn.execute("SELECT * FROM subscribers WHERE id=?", (sub_id,)).fetchone()
    if not row:
        conn.close()
        return jsonify({"ok": False, "error": "Subscriber not found"}), 404
    
    appt_id = str(uuid.uuid4())
    conn.execute("""INSERT INTO saas_appointments
        (id, subscriber_id, name, email, company, phone, qual_score,
         slot_date, slot_time, meeting_link, status, notes)
        VALUES (?,?,?,?,?,?,?,?,?,'https://cal.com/murphysystems','confirmed',?)""",
        (appt_id, sub_id, row['name'], row['email'], row['company'],
         row['phone'], row['qual_score'], slot_dt, slot_tm, notes))
    conn.execute("UPDATE subscribers SET status='appointment_booked' WHERE id=?", (sub_id,))
    conn.commit()
    conn.close()
    
    return jsonify({
        "ok": True,
        "appointment_id": appt_id,
        "slot": f"{slot_dt} {slot_tm}",
        "next": f"/ui/contract?id={sub_id}&tier=owner_operator"
    })

@app.route('/api/saas/send-contract', methods=['POST'])
def saas_send_contract_335():
    """Generate contract and send via email."""
    import sqlite3, uuid, json
    from datetime import datetime, timedelta
    
    data = request.get_json() or {}
    sub_id = data.get('id') or ''
    tier = data.get('tier') or 'owner_operator'
    
    TIERS = {
        "owner_operator": {"monthly": 100.0, "term": 12},
        "professional": {"monthly": 299.0, "term": 12},
        "enterprise": {"monthly": 599.0, "term": 24},
    }
    t = TIERS.get(tier, TIERS["owner_operator"])
    monthly = t["monthly"]
    term = t["term"]
    total = monthly * term
    pct60 = round(total * 0.60, 2)
    
    conn = sqlite3.connect("/var/lib/murphy-production/saas_subscribers.db")
    conn.row_factory = sqlite3.Row
    row = conn.execute("SELECT * FROM subscribers WHERE id=?", (sub_id,)).fetchone()
    if not row:
        conn.close()
        return jsonify({"ok": False, "error": "Subscriber not found"}), 404
    
    backlog_start = (datetime.utcnow() + timedelta(days=183)).strftime('%B %d, %Y')
    contract_id = str(uuid.uuid4())
    
    conn.execute("""INSERT INTO contracts
        (id, subscriber_id, contract_value_usd, monthly_usd, term_months,
         payment_60pct_usd, backlog_start_date, status)
        VALUES (?,?,?,?,?,?,?,'sent')""",
        (contract_id, sub_id, total, monthly, term, pct60, backlog_start))
    conn.execute("UPDATE subscribers SET status='contract_sent' WHERE id=?", (sub_id,))
    conn.commit()
    conn.close()
    
    return jsonify({
        "ok": True,
        "contract_id": contract_id,
        "monthly": monthly,
        "total": total,
        "pct60_due": pct60,
        "backlog_start": backlog_start,
        "contract_url": f"/ui/contract?id={sub_id}&contract={contract_id}"
    })

@app.route('/api/saas/backlog/<sub_id>', methods=['GET'])
def saas_backlog_335(sub_id):
    """Return work backlog for a subscriber."""
    import sqlite3
    conn = sqlite3.connect("/var/lib/murphy-production/saas_subscribers.db")
    conn.row_factory = sqlite3.Row
    items = [dict(r) for r in
             conn.execute("""SELECT * FROM work_backlog WHERE subscriber_id=?
                            ORDER BY priority, created_at""", (sub_id,)).fetchall()]
    conn.close()
    return jsonify({"ok": True, "items": items, "count": len(items)})

