# PATCH-335B — Owner-Operator SaaS API Routes (Complete)
# ════════════════════════════════════════════════════════════════════════════════

import sqlite3 as _s335b, uuid as _u335b, json as _j335b
from datetime import datetime as _dt335b, timedelta as _td335b

_SAASDB = "/var/lib/murphy-production/saas_subscribers.db"

def _init_sdb():
    conn = _s335b.connect(_SAASDB)
    conn.row_factory = _s335b.Row
    conn.executescript("""CREATE TABLE IF NOT EXISTS subscribers(id TEXT PRIMARY KEY,email TEXT UNIQUE,name TEXT,company TEXT,phone TEXT,team_size INT DEFAULT 1,industry TEXT,workflows TEXT DEFAULT '[]',qual_score INT DEFAULT 0,tier TEXT DEFAULT 'owner_operator',status TEXT DEFAULT 'lead',source TEXT DEFAULT 'website',created_at TEXT DEFAULT (datetime('now')),updated_at TEXT DEFAULT (datetime('now')));CREATE TABLE IF NOT EXISTS contracts(id TEXT PRIMARY KEY,subscriber_id TEXT NOT NULL,contract_value_usd REAL DEFAULT 0,monthly_usd REAL DEFAULT 100,term_months INT DEFAULT 12,payment_60pct_usd REAL DEFAULT 0,amount_paid_usd REAL DEFAULT 0,threshold_met INT DEFAULT 0,backlog_start_date TEXT DEFAULT '',status TEXT DEFAULT 'draft');CREATE TABLE IF NOT EXISTS work_backlog(id TEXT PRIMARY KEY,subscriber_id TEXT,contract_id TEXT,title TEXT NOT NULL,description TEXT,priority INT DEFAULT 5,status TEXT DEFAULT 'queued',unlock_date TEXT DEFAULT '');CREATE TABLE IF NOT EXISTS saas_appointments(id TEXT PRIMARY KEY,subscriber_id TEXT,name TEXT NOT NULL,email TEXT NOT NULL,company TEXT,phone TEXT,slot_date TEXT NOT NULL,slot_time TEXT NOT NULL,status TEXT DEFAULT 'confirmed')""")
    conn.commit()
    return conn

@app.route('/api/saas/lead', methods=['POST'])
def api_saas_lead():
    """Capture a new lead from the website."""
    data = request.get_json() or {}
    email = (data.get('email') or '').strip().lower()
    if not email or '@' not in email:
        return jsonify({"ok": False, "error": "Email required"}), 400
    
    conn = _init_sdb()
    existing = conn.execute("SELECT id FROM subscribers WHERE email=?", (email,)).fetchone()
    if existing:
        conn.close()
        return jsonify({"ok": True, "id": existing[0], "existing": True})
    
    sub_id = str(_u335b.uuid4())
    conn.execute(
        "INSERT INTO subscribers(id, email, name, company, phone, team_size, industry, source, status) "
        "VALUES(?, ?, ?, ?, ?, ?, ?, ?, 'lead')",
        (sub_id, email, data.get('name', ''), data.get('company', ''), data.get('phone', ''),
         int(data.get('team_size') or 1), data.get('industry', 'general'), data.get('source', 'website'))
    )
    conn.commit()
    conn.close()
    return jsonify({"ok": True, "id": sub_id, "next": f"/ui/qualify?id={sub_id}"})

@app.route('/api/saas/qualify', methods=['POST'])
def api_saas_qualify():
    """Score and route a lead."""
    data = request.get_json() or {}
    sub_id = data.get('id') or ''
    
    conn = _init_sdb()
    row = conn.execute("SELECT * FROM subscribers WHERE id=?", (sub_id,)).fetchone()
    if not row:
        conn.close()
        return jsonify({"ok": False, "error": "Not found"}), 404
    
    # Simple scoring
    score = 50 + (20 if row[6] and 'hvac' in (row[6] or '').lower() else 0)
    route = "book_call" if score >= 70 else ("self_serve" if score >= 50 else "nurture")
    tier = "enterprise" if score >= 70 else ("owner_operator" if score >= 50 else "nurture")
    
    conn.execute(
        "UPDATE subscribers SET workflows=?, qual_score=?, tier=?, status=?, updated_at=datetime('now') WHERE id=?",
        (_j335b.dumps(data.get('workflows', [])), score, tier, 
         'qualified' if route != 'nurture' else 'nurture', sub_id)
    )
    conn.commit()
    conn.close()
    
    next_url = {
        "book_call": f"/ui/book-call?id={sub_id}",
        "self_serve": f"/ui/contract?id={sub_id}&tier=owner_operator",
        "nurture": "/ui/start?nurture=1"
    }[route]
    
    return jsonify({"ok": True, "score": score, "route": route, "next": next_url})

@app.route('/api/saas/send-contract', methods=['POST'])
def api_saas_send_contract():
    """Generate and send contract."""
    data = request.get_json() or {}
    sub_id = data.get('id') or ''
    tier = data.get('tier') or 'owner_operator'
    
    monthly = 100 if tier == 'owner_operator' else (299 if tier == 'professional' else 599)
    term = 12
    total = monthly * term
    pct60 = round(total * 0.6, 2)
    backlog_start = (_dt335b.utcnow() + _td335b(days=183)).strftime('%B %d, %Y')
    contract_id = str(_u335b.uuid4())
    
    conn = _init_sdb()
    conn.execute(
        "INSERT INTO contracts(id, subscriber_id, contract_value_usd, monthly_usd, term_months, payment_60pct_usd, backlog_start_date, status) "
        "VALUES(?, ?, ?, ?, ?, ?, ?, 'sent')",
        (contract_id, sub_id, total, monthly, term, pct60, backlog_start)
    )
    conn.execute("UPDATE subscribers SET status='contract_sent' WHERE id=?", (sub_id,))
    conn.commit()
    conn.close()
    
    return jsonify({
        "ok": True,
        "contract_id": contract_id,
        "monthly": monthly,
        "total": total,
        "pct60_due": pct60,
        "backlog_start": backlog_start
    })

@app.route('/api/saas/payment-confirm', methods=['POST'])
def api_saas_payment_confirm():
    """Confirm payment and unlock backlog."""
    data = request.get_json() or {}
    contract_id = data.get('contract_id') or ''
    amount_paid = float(data.get('amount_usd') or 0)
    
    conn = _init_sdb()
    c = conn.execute("SELECT * FROM contracts WHERE id=?", (contract_id,)).fetchone()
    if not c:
        conn.close()
        return jsonify({"ok": False, "error": "Not found"}), 404
    
    new_total = (c[7] or 0) + amount_paid
    threshold_met = 1 if new_total >= c[5] else 0
    
    if threshold_met and not c[8]:
        # Create backlog items
        sub_id = c[1]
        for title, desc in [("Lead form live", "Embed capture widget"), ("Qualification active", "Auto-score leads"), ("Booking configured", "Calendar + reminders")]:
            conn.execute(
                "INSERT INTO work_backlog(id, subscriber_id, contract_id, title, description, priority, status) "
                "VALUES(?, ?, ?, ?, ?, 1, 'queued')",
                (str(_u335b.uuid4()), sub_id, contract_id, title, desc)
            )
        conn.execute("UPDATE subscribers SET status='active' WHERE id=?", (sub_id,))
    
    conn.execute(
        "UPDATE contracts SET amount_paid_usd=?, threshold_met=?, status=CASE WHEN ? THEN 'active' ELSE status END WHERE id=?",
        (new_total, threshold_met, threshold_met, contract_id)
    )
    conn.commit()
    conn.close()
    
    return jsonify({"ok": True, "amount_paid": new_total, "threshold_met": bool(threshold_met)})

@app.route('/api/saas/status/<eid>', methods=['GET'])
def api_saas_status(eid):
    """Return subscriber status."""
    conn = _init_sdb()
    row = conn.execute("SELECT * FROM subscribers WHERE email=? OR id=?", (eid.lower(), eid)).fetchone()
    conn.close()
    if not row:
        return jsonify({"ok": False}), 404
    return jsonify({"ok": True, "status": "active"})

# ════════════════════════════════════════════════════════════════════════════════
# END PATCH-335B SaaS API
