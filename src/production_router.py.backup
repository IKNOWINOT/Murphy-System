@app.route('/api/ghost/pending/<device_id>', methods=['POST'])
def ghost_pending_327(device_id):
    """Return pending golden path steps for a registered device"""
    import json
    try:
        import sqlite3
        db = _os327.path.join(_ROOT_DIR_327, 'ghost_training.db')
        if not _os327.path.exists(db):
            return jsonify({"steps": [], "device_id": device_id})
        conn = sqlite3.connect(db)
        cur = conn.cursor()
        cur.execute("SELECT id, task, steps FROM ghost_dispatch WHERE device_id=? AND status='pending' LIMIT 5", (device_id,))
        rows = cur.fetchall()
        conn.close()
        steps = [{"dispatch_id": r[0], "task": r[1], "steps": json.loads(r[2] or "[]")} for r in rows]
        return jsonify({"steps": steps, "device_id": device_id})
    except Exception as e:
        return jsonify({"steps": [], "error": str(e)})

@app.route('/api/ghost/clear/<device_id>', methods=['POST'])
def ghost_clear_327(device_id):
    """Mark dispatched steps as completed for a device"""
    try:
        import sqlite3
        db = _os327.path.join(_ROOT_DIR_327, 'ghost_training.db')
        if _os327.path.exists(db):
            conn = sqlite3.connect(db)
            conn.execute("UPDATE ghost_dispatch SET status='done' WHERE device_id=? AND status='pending'", (device_id,))
            conn.commit()
            conn.close()
        return jsonify({"success": True, "device_id": device_id})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route('/api/ghost/register', methods=['POST'])
def ghost_register_327():
    """Register a Murphy client device"""
    import sqlite3, json, uuid
    data = request.get_json() or {}
    device_id = data.get('device_id') or str(uuid.uuid4())
    device_name = data.get('device_name', 'Unknown')
    platform = data.get('platform', 'unknown')
    try:
        db = _os327.path.join(_ROOT_DIR_327, 'ghost_training.db')
        conn = sqlite3.connect(db)
        conn.execute("""CREATE TABLE IF NOT EXISTS ghost_devices
            (device_id TEXT PRIMARY KEY, device_name TEXT, platform TEXT, registered_at TEXT)""")
        conn.execute("""INSERT OR REPLACE INTO ghost_devices VALUES (?,?,?,datetime('now'))""",
                    (device_id, device_name, platform))
        conn.commit()
        conn.close()
        return jsonify({"success": True, "device_id": device_id, "device_name": device_name})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route('/api/ghost/training', methods=['POST'])
def ghost_training_327():
    """Log a completed golden path training event"""
    import sqlite3, json
    data = request.get_json() or {}
    device_id = data.get('device_id', 'unknown')
    task = data.get('task', '')
    steps = data.get('steps', [])
    try:
        db = _os327.path.join(_ROOT_DIR_327, 'ghost_training.db')
        conn = sqlite3.connect(db)
        conn.execute("""CREATE TABLE IF NOT EXISTS ghost_training_events
            (id INTEGER PRIMARY KEY AUTOINCREMENT, device_id TEXT, task TEXT,
             steps TEXT, recorded_at TEXT)""")
        conn.execute("INSERT INTO ghost_training_events VALUES (NULL,?,?,?,datetime('now'))",
                    (device_id, task, json.dumps(steps)))
        conn.commit()
        conn.close()
        return jsonify({"success": True, "task": task, "steps_logged": len(steps)})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route('/api/ghost/probmap', methods=['GET'])
def ghost_probmap_327():
    """Return probability map for golden path suggestions"""
    import sqlite3, json
    try:
        db = _os327.path.join(_ROOT_DIR_327, 'ghost_training.db')
        if not _os327.path.exists(db):
            return jsonify({"probmap": {}, "total_events": 0})
        conn = sqlite3.connect(db)
        cur = conn.cursor()
        cur.execute("SELECT task, COUNT(*) as cnt FROM ghost_training_events GROUP BY task ORDER BY cnt DESC LIMIT 50")
        rows = cur.fetchall()
        conn.close()
        probmap = {r[0]: r[1] for r in rows}
        return jsonify({"probmap": probmap, "total_events": sum(probmap.values())})
    except Exception as e:
        return jsonify({"probmap": {}, "error": str(e)})


