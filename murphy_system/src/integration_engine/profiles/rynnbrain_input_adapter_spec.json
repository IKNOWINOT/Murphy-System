{
  "_note": "Murphy-internal input adapter spec for RynnBrain. Generated by SandboxQuarantine data-schema extractor. Describes how to translate between Murphy's internal data format and RynnBrain's wire format.",
  "module_name": "rynnbrain",
  "spec_version": "1.0.0",
  "generated_by": "SandboxQuarantine.input_schema_extractor",
  "source_commit": "4e694f27d5a23b3c3b487be1a97e708c15cb9fd4",

  "detected_formats": [
    "conversation_json",
    "bounding_box_output",
    "planning_stream",
    "navigation_trajectory"
  ],

  "murphy_to_thirdparty": [
    {
      "murphy_field": "prompt.text",
      "thirdparty_field": "messages[].content[{type:'text'}].text",
      "transform": "wrap_text_in_content_block",
      "notes": "Murphy text prompt becomes a typed text content block in the last user message"
    },
    {
      "murphy_field": "prompt.images[]",
      "thirdparty_field": "messages[].content[{type:'image'}].image",
      "transform": "wrap_images_as_content_blocks",
      "notes": "Each Murphy image path/URL becomes a typed image content block, prepended before text"
    },
    {
      "murphy_field": "prompt.system",
      "thirdparty_field": "messages[0] where role='system'",
      "transform": "prepend_system_message",
      "notes": "Murphy system prompt becomes a separate system role message at the start of the conversation"
    },
    {
      "murphy_field": "task_type",
      "thirdparty_field": "model_variant_hint",
      "transform": "map_task_to_variant",
      "notes": "PLANNING→RynnBrain-Plan, NAVIGATION→RynnBrain-Nav, GENERAL→RynnBrain-8B (default)"
    }
  ],

  "thirdparty_to_murphy": [
    {
      "thirdparty_field": "model_output (text containing <label> (x1,y1), (x2,y2) </label>)",
      "murphy_field": "bounding_boxes[]",
      "transform": "parse_object_tags",
      "pattern": "<(\\S+?)>\\s*\\((\\d+)\\s*,\\s*(\\d+)\\)\\s*,\\s*\\((\\d+)\\s*,\\s*(\\d+)\\)\\s*</\\S+?>",
      "output_schema": {
        "label": "string",
        "x1": "int",
        "y1": "int",
        "x2": "int",
        "y2": "int"
      },
      "notes": "Extract all <label> (x1,y1), (x2,y2) </label> spans from model text output"
    },
    {
      "thirdparty_field": "model_output (planning stream JSON or numbered text)",
      "murphy_field": "plan_steps[]",
      "transform": "parse_planning_stream",
      "output_schema": {
        "step_index": "int",
        "action": "string",
        "reasoning": "string"
      },
      "notes": "Parse JSON step objects or numbered text steps from planning output"
    },
    {
      "thirdparty_field": "model_output (navigation trajectory JSON)",
      "murphy_field": "nav_trajectory[]",
      "transform": "parse_navigation_trajectory",
      "output_schema": {
        "step": "int",
        "position": ["float", "float", "float"],
        "heading": "float",
        "action": "string"
      },
      "notes": "Parse trajectory array or {trajectory:[...]} JSON from navigation output"
    }
  ],

  "example_murphy_input": {
    "prompt": {
      "text": "What objects are on the table? Provide bounding boxes.",
      "images": ["/path/to/scene.jpg"],
      "system": "You are an embodied AI assistant. Use spatial reasoning.",
      "task_type": "general"
    }
  },

  "example_rynnbrain_payload": {
    "messages": [
      {
        "role": "system",
        "content": [{"type": "text", "text": "You are an embodied AI assistant. Use spatial reasoning."}]
      },
      {
        "role": "user",
        "content": [
          {"type": "image", "image": "/path/to/scene.jpg"},
          {"type": "text", "text": "What objects are on the table? Provide bounding boxes."}
        ]
      }
    ],
    "model_id": "Alibaba-DAMO-Academy/RynnBrain-8B",
    "revision": "4e694f27d5a23b3c3b487be1a97e708c15cb9fd4"
  },

  "example_rynnbrain_output": {
    "text": "On the table I can see: <cup> (120,80), (180,150) </cup> <book> (200,60), (320,180) </book>"
  },

  "example_murphy_output": {
    "bounding_boxes": [
      {"label": "cup",  "x1": 120, "y1": 80,  "x2": 180, "y2": 150},
      {"label": "book", "x1": 200, "y1": 60,  "x2": 320, "y2": 180}
    ]
  }
}
