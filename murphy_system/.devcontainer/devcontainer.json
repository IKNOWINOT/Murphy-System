{
  "name": "Murphy System Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
  "forwardPorts": [8000, 5173, 8090],
  "portsAttributes": {
    "8000": { "label": "Murphy API", "onAutoForward": "notify" },
    "5173": { "label": "Murphy Web UI (Vite)", "onAutoForward": "notify" },
    "8090": { "label": "Murphy Static UIs", "onAutoForward": "notify" }
  },
  "postCreateCommand": "bash setup_and_start.sh --dev-only",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-azuretools.vscode-docker",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
        "editor.formatOnSave": true,
        "editor.rulers": [120],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder}/.env,target=${containerWorkspaceFolder}/.env,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "MURPHY_ENV": "development",
    "PYTHONPATH": "${containerWorkspaceFolder}/src"
  }
}
