# Encrypted key files generated at runtime
*.enc

# PROD-HARD-SEC-001 (audit G14, G15): prevent accidental commit of secrets
# and patch-artifact .bak files (which is how src/runtime/app.py.patch001.bak
# and src/fastapi_security.py.patch001.bak got into the tree previously).
*.bak
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
.aws/
.ssh/

# Mail server TLS certificates (generated at deploy time, not tracked)
config/mail/ssl/

# Mail server account database (generated at deploy time by scripts/mail_setup.sh)
config/mail/postfix-accounts.cf

# Production environment file (written by CI/CD deploy workflow — never commit)
/etc/murphy-production/environment

# Local environment overrides
*.env.local

# Test result artifacts (generated by test_storyline_actuals.py)
Murphy System/docs/storyline_test_results.json
Murphy System/docs/storyline_test_results_phase2.json
Murphy System/docs/storyline_test_results_phase3.json
*.db
*.db-wal
*.db-shm
.chroma/

# Telemetry evidence — runtime artifacts only (evidence IS committed so reviewers can read it)
telemetry_evidence/**/*.pid
telemetry_evidence/**/*.xml
telemetry_evidence/telemetry_log.jsonl
.coverage

# Server-generated pip lockfile (environment-specific, regenerated on deploy)
requirements.lock

# Generated UI artifacts from agent sessions
Murphy System/tests/*.html
Murphy System/tests/murphy_landing_page.html
Murphy System/tests/murphy_system_1.0_runtime.py
Murphy System/tests/murphy_terminal.py

# Agent-generated solution paths
data/solution_paths/*.json

# PSM-002 platform self-modification ledger (immutable runtime artifact)
data/platform_self_edit_ledger.jsonl
