# ── Default behavior ─────────────────────────────────────────────────────────
# Normalize line endings to LF in the repository; check out as LF on all OSes.
* text=auto eol=lf

# ── Source code ──────────────────────────────────────────────────────────────
*.py        text eol=lf diff=python
*.ts        text eol=lf diff=typescript
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf

# ── Data and configuration ────────────────────────────────────────────────────
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf

# ── Documentation ────────────────────────────────────────────────────────────
*.md        text eol=lf diff=markdown
*.txt       text eol=lf
*.rst       text eol=lf

# ── Shell scripts ─────────────────────────────────────────────────────────────
*.sh        text eol=lf
*.bash      text eol=lf

# Windows batch files — must keep CRLF line endings
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ── Web assets ───────────────────────────────────────────────────────────────
*.html      text eol=lf diff=html
*.css       text eol=lf
*.scss      text eol=lf
*.svg       text eol=lf

# ── Build and packaging ───────────────────────────────────────────────────────
Makefile    text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
requirements*.txt text eol=lf
setup.py    text eol=lf
setup.cfg   text eol=lf
pyproject.toml text eol=lf
MANIFEST.in text eol=lf

# ── Certificates and keys ─────────────────────────────────────────────────────
*.pem       text eol=lf
*.crt       text eol=lf
*.key       text eol=lf

# ── Binary files (do not diff or modify) ──────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.bz2       binary
*.xz        binary
*.whl       binary
*.egg       binary
*.pyc       binary
*.pyd       binary
*.so        binary
*.dylib     binary
*.dll       binary
*.exe       binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary

# ── GitHub-specific ───────────────────────────────────────────────────────────
# Mark generated / vendored files so they are excluded from GitHub language stats
# and code review diffs.
*.lock      linguist-generated
package-lock.json linguist-generated
yarn.lock   linguist-generated

# OpenAPI schema is mechanically generated from the FastAPI app by
# scripts/export_openapi.py; the CI `openapi-check` job blocks merges if it
# drifts from the source code. Mark as generated so GitHub collapses the diff
# in PR review and excludes it from language stats. The `-diff` attribute
# suppresses git's textual diff for this file (it's ~880 KB; reviewers should
# inspect the rendered API docs, not a line-by-line diff).
docs/openapi.json linguist-generated -diff
