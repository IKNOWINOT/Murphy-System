# Murphy System 1.0 - Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (in the same directory)
# 2. Fill in at least GROQ_API_KEY (free at https://console.groq.com)
# 3. Save and start Murphy with ./start_murphy_1.0.sh
#
# Copyright © 2020 Inoni Limited Liability Company
# Creator: Corey Post
# License: Apache License 2.0

# ============= CORE CONFIGURATION (Required) =============

# Murphy System Version
MURPHY_VERSION=1.0.0

# Environment (development, staging, production)
# WARNING: In development mode, API authentication is DISABLED.
# All endpoints (including /api/execute) are accessible without a key.
# Set MURPHY_ENV=production and configure MURPHY_API_KEYS for production use.
MURPHY_ENV=development

# Port number (default: 8000)
MURPHY_PORT=8000

# ============= LLM API KEYS (At least one required) =============

# LLM Provider selection (groq, openai, or anthropic)
# If not set, Murphy will auto-detect from whichever API key is available below.
MURPHY_LLM_PROVIDER=groq

# Groq (Recommended for getting started - FREE tier available)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq API key pool (comma-separated, for load balancing / rate-limit rotation)
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Aristotle deterministic engine (optional external API)
# ARISTOTLE_API_KEY=your_aristotle_api_key_here
# ARISTOTLE_API_URL=https://api.aristotle.example.com/v1/analyze

# Wulfrum fuzzy-match engine (optional external API)
# WULFRUM_API_KEY=your_wulfrum_api_key_here
# WULFRUM_API_URL=https://api.wulfrum.example.com/v1/validate

# OpenAI (Optional - for GPT-4 features)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic Claude (Optional)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ============= DATABASE (Optional - SQLite auto-created if omitted) =============

# PostgreSQL (Recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/murphy

# MySQL (Alternative)
# DATABASE_URL=mysql://username:password@localhost:3306/murphy

# SQLite (Default - no configuration needed)
# Automatically uses: sqlite:///./murphy_system.db

# ============= CACHE (Optional - in-memory cache if omitted) =============

# Redis (Recommended for production)
# REDIS_URL=redis://localhost:6379/0

# Redis with password
# REDIS_URL=redis://:password@localhost:6379/0

# ============= SECURITY (Auto-generated if not provided) =============

# JWT Secret (for API authentication)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=your-secret-key-here

# Encryption Key (for sensitive data)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY=your-encryption-key-here

# ============= GITHUB INTEGRATION (Optional) =============

# GitHub Personal Access Token
# Get your token at: https://github.com/settings/tokens
# Required for: Private repository integration, higher rate limits
# GITHUB_TOKEN=ghp_your_github_token_here

# ============= PAYMENT PROCESSING (Optional) =============

# Stripe (for payment processing)
# Get your keys at: https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_test_your_stripe_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# PayPal (alternative payment processor)
# Get your credentials at: https://developer.paypal.com/
# PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# ============= EMAIL & MESSAGING (Optional) =============

# SendGrid (for email automation)
# Get your key at: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.your_sendgrid_key_here

# AWS SES (alternative email service)
# AWS_SES_ACCESS_KEY=your_aws_access_key_here
# AWS_SES_SECRET_KEY=your_aws_secret_key_here
# AWS_SES_REGION=us-east-1

# Twilio (for SMS automation)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ============= CRM INTEGRATION (Optional) =============

# Salesforce (for sales automation)
# SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
# SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret_here
# SALESFORCE_USERNAME=your_salesforce_username_here
# SALESFORCE_PASSWORD=your_salesforce_password_here

# HubSpot (alternative CRM)
# Get your key at: https://app.hubspot.com/settings/api-key
# HUBSPOT_API_KEY=your_hubspot_api_key_here

# Pipedrive (alternative CRM)
# PIPEDRIVE_API_TOKEN=your_pipedrive_token_here

# ============= SOCIAL MEDIA (Optional) =============

# Twitter/X (for social media automation)
# TWITTER_API_KEY=your_twitter_api_key_here
# TWITTER_API_SECRET=your_twitter_api_secret_here
# TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
# TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# LinkedIn (for professional social media)
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Facebook (for social media automation)
# FACEBOOK_APP_ID=your_facebook_app_id_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here
# FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# ============= ANALYTICS (Optional) =============

# Google Analytics (for marketing analytics)
# GOOGLE_ANALYTICS_ID=UA-your_analytics_id_here
# GOOGLE_ANALYTICS_KEY=your_analytics_key_here

# ============= CONTENT MANAGEMENT (Optional) =============

# WordPress (for blog publishing)
# WORDPRESS_URL=https://your-site.com
# WORDPRESS_USERNAME=your_wordpress_username_here
# WORDPRESS_PASSWORD=your_wordpress_app_password_here

# Medium (for blog publishing)
# MEDIUM_ACCESS_TOKEN=your_medium_token_here

# ============= MONITORING & LOGGING (Optional) =============

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry (for error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# Prometheus (for metrics)
# PROMETHEUS_PORT=9090

# ============= DEVELOPMENT OPTIONS (Optional) =============

# Debug Mode (true/false)
DEBUG=false

# Auto-reload on code changes (true/false)
AUTO_RELOAD=true

# Enable CORS (for development)
ENABLE_CORS=true

# Allowed Origins (comma-separated) — Do NOT use '*' in production
MURPHY_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# API Keys for authentication (comma-separated)
# In development mode (MURPHY_ENV=development), auth is optional.
# In production/staging, requests without a valid key are rejected (401).
# MURPHY_API_KEYS=murphy_abc123,murphy_def456

# ============= NOTES =============
#
# MINIMAL SETUP (Development):
# - Just set GROQ_API_KEY and you're ready to go!
# - Everything else is optional
#
# RECOMMENDED SETUP (Development):
# - GROQ_API_KEY (required)
# - GITHUB_TOKEN (for repository integration)
# - DEBUG=true (for development)
#
# PRODUCTION SETUP:
# - All required keys from your integrations
# - MURPHY_ENV=production
# - MURPHY_API_KEYS=<your secure API keys>
# - MURPHY_CORS_ORIGINS=<your allowed origins>
# - DATABASE_URL (PostgreSQL)
# - REDIS_URL (Redis)
# - JWT_SECRET (strong secret)
# - ENCRYPTION_KEY (strong secret — use a secrets manager, not .env)
# - DEBUG=false
# - Proper security headers
#
# ============= END CONFIGURATION =============
