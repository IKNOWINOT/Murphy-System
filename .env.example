# Murphy System 1.0 - Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Run: bash setup_and_start.sh — it auto-generates .env for you.
#    You do NOT need to copy this file manually.
# 2. The onboard LLM works without any external API key.
#    Optionally add DEEPINFRA_API_KEY for enhanced quality (free at https://deepinfra.com).
# 3. In development mode, API authentication is disabled.
#    In staging and production modes, MURPHY_API_KEYS must be configured.
#
# Copyright © 2020 Inoni Limited Liability Company
# Creator: Corey Post
# License: BSL 1.1

# ============= CORE CONFIGURATION (Required) =============

# Murphy System Version
MURPHY_VERSION=1.0.0

# Environment: development | staging | production
#
#   development — Authentication is DISABLED (local dev only, never deploy)
#   staging     — Authentication is ENABLED; verbose error messages allowed
#   production  — Authentication is ENABLED; minimal error exposure
#
# WARNING: deployment environments should always use 'staging' or 'production'.
# Deploying with MURPHY_ENV=development leaves ALL endpoints unauthenticated.
# NOTE: Use a secrets manager (Vault, AWS Secrets Manager, k8s Secrets) instead
# of this .env file for production credentials.
# CHANGED TO development FOR NEW DEVELOPER EXPERIENCE.
# Switch to staging or production when deploying. See notes at bottom.
MURPHY_ENV=development

# Port number (default: 8000)
MURPHY_PORT=8000

# Persistence directory for JSON snapshots
MURPHY_PERSISTENCE_DIR=.murphy_persistence

# ============= LLM API KEYS (Optional — onboard LLM works without any key) =============

# LLM Provider selection (local, deepinfra, openai, or anthropic)
# Defaults to 'local' — the onboard LLM requires no external API key.
# Set to 'deepinfra', 'openai', or 'anthropic' once you add a key below.
MURPHY_LLM_PROVIDER=local

# DeepInfra (Recommended for enhanced quality - FREE tier available)
# Get your key at: https://deepinfra.com
# DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# DeepInfra API key pool (comma-separated, for load balancing / rate-limit rotation)
# DEEPINFRA_API_KEYS=di_key1,di_key2,di_key3

# Aristotle deterministic engine (optional external API)
# ARISTOTLE_API_KEY=your_aristotle_api_key_here
# ARISTOTLE_API_URL=https://api.aristotle.example.com/v1/analyze

# Wulfrum fuzzy-match engine (optional external API)
# WULFRUM_API_KEY=your_wulfrum_api_key_here
# WULFRUM_API_URL=https://api.wulfrum.example.com/v1/validate

# OpenAI (Optional - for GPT-4 features)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic Claude (Optional)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ============= DATABASE (Optional - SQLite auto-created if omitted) =============

# PostgreSQL (Recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/murphy

# MySQL (Alternative)
# DATABASE_URL=mysql://username:password@localhost:3306/murphy

# SQLite (Default - no configuration needed)
# Automatically uses: sqlite:///./murphy_system.db

# Database connector mode.
# stub = deterministic in-memory responses (dev/test only — LARGE WARNING in logs)
# live = real SQLAlchemy database (requires DATABASE_URL)
# CRITICAL: MURPHY_DB_MODE=stub is REJECTED at startup in production/staging.
# MURPHY_DB_MODE=stub

# Automatic Alembic migrations on startup.
# true  = apply pending migrations automatically (default in development/test)
# false = skip auto-migration; run scripts/db_migrate.sh manually (default in production/staging)
# MURPHY_AUTO_MIGRATE=true

# SQLAlchemy connection pool settings (PostgreSQL / MySQL; ignored for SQLite).
# MURPHY_DB_POOL_SIZE=5
# MURPHY_DB_MAX_OVERFLOW=10

# ============= CACHE (Optional - in-memory cache if omitted) =============

# Redis (Recommended for production)
# REDIS_URL=redis://localhost:6379/0

# Redis with password
# REDIS_URL=redis://:password@localhost:6379/0

# Redis for multi-worker rate limiting (required when uvicorn runs with --workers > 1)
# Generate connection URL: redis://localhost:6379/0
# MURPHY_REDIS_URL=redis://localhost:6379/0

# ============= DOCKER COMPOSE CREDENTIALS (Required for `docker compose up`) ======
# These variables are required by docker-compose.yml.  Set them before running
# `docker compose up` or the compose file will refuse to start.
#
# Generate strong random values:
#   POSTGRES_PASSWORD=$(python -c "import secrets; print(secrets.token_urlsafe(24))")
#   REDIS_PASSWORD=$(python -c "import secrets; print(secrets.token_urlsafe(24))")
#   GRAFANA_ADMIN_PASSWORD=$(python -c "import secrets; print(secrets.token_urlsafe(16))")

POSTGRES_PASSWORD=CHANGEME_generate_a_strong_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_generate_a_strong_password
# REDIS_PASSWORD=  # Optional but recommended for production

# ============= SECURITY (Auto-generated if not provided) =============

# Credential Master Key — used to encrypt private keys at rest (Fernet AES-128-CBC)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in staging/production. In development, an ephemeral per-process key is used.
# MURPHY_CREDENTIAL_MASTER_KEY=your_fernet_key_here

# API Keys for authentication (comma-separated)
# REQUIRED in staging/production. Use a secrets manager in production (see below).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MURPHY_API_KEYS=murphy_key1,murphy_key2

# JWT Secret (for API authentication)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MURPHY_JWT_SECRET=your-jwt-secret-here

# Encryption Key (for sensitive data)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY=your-encryption-key-here

# ============= OAUTH / SOCIAL SIGN-IN (Optional) =============
#
# Enables "Continue with Google / GitHub / Meta / LinkedIn / Apple" sign-in buttons.
# Without these, the buttons redirect to the login page with a friendly
# "not yet available" message — the app continues to work with email sign-in.
#
# Short names (GOOGLE_CLIENT_ID, etc.) are accepted as well as the full
# MURPHY_OAUTH_* names — the Murphy-namespaced form takes precedence.
#
# Redirect URI — must match what you register in each OAuth app dashboard.
# MURPHY_OAUTH_REDIRECT_URI=https://murphy.systems/api/auth/callback

# Google OAuth 2.0 — https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
# MURPHY_OAUTH_GOOGLE_SECRET=your_google_client_secret_here

# GitHub OAuth — https://github.com/settings/developers
# GITHUB_CLIENT_ID=your_github_client_id_here
# GITHUB_CLIENT_SECRET=your_github_client_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_GITHUB_CLIENT_ID=your_github_client_id_here
# MURPHY_OAUTH_GITHUB_SECRET=your_github_client_secret_here

# Meta (Facebook) Login — https://developers.facebook.com/apps/
# META_CLIENT_ID=your_meta_app_id_here
# META_CLIENT_SECRET=your_meta_app_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_META_CLIENT_ID=your_meta_app_id_here
# MURPHY_OAUTH_META_SECRET=your_meta_app_secret_here

# LinkedIn Login — https://www.linkedin.com/developers/apps
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# MURPHY_OAUTH_LINKEDIN_SECRET=your_linkedin_client_secret_here

# Sign in with Apple — https://developer.apple.com/account/resources/authkeys/list
# APPLE_CLIENT_ID=your.apple.service.id
# APPLE_CLIENT_SECRET=your_apple_client_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_APPLE_CLIENT_ID=your.apple.service.id
# MURPHY_OAUTH_APPLE_SECRET=your_apple_client_secret_here

# Microsoft / Azure AD — https://portal.azure.com/#view/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade
# MICROSOFT_CLIENT_ID=your_azure_app_client_id_here
# MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret_here
# (Alternate namespaced form)
# MURPHY_OAUTH_MICROSOFT_CLIENT_ID=your_azure_app_client_id_here
# MURPHY_OAUTH_MICROSOFT_SECRET=your_azure_app_client_secret_here

# ============= GITHUB INTEGRATION (Optional) =============

# GitHub Personal Access Token
# Get your token at: https://github.com/settings/tokens
# Required for: Private repository integration, higher rate limits
# GITHUB_TOKEN=ghp_your_github_token_here

# ============= PAYMENT PROCESSING (Optional) =============

# Stripe (for payment processing)
# Get your keys at: https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_test_your_stripe_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# PayPal (primary payment processor)
# Get your credentials at: https://developer.paypal.com/
# PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# PAYPAL_WEBHOOK_SECRET=your_paypal_webhook_secret_here

# Coinbase Commerce (crypto payments)
# Configure at: https://commerce.coinbase.com/settings
# COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret_here

# ============= EMAIL & MESSAGING (Optional) =============

# SendGrid (for email automation)
# Get your key at: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.your_sendgrid_key_here

# AWS SES (alternative email service)
# AWS_SES_ACCESS_KEY=your_aws_access_key_here
# AWS_SES_SECRET_KEY=your_aws_secret_key_here
# AWS_SES_REGION=us-east-1

# Twilio (for SMS automation)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ============= CRM INTEGRATION (Optional) =============

# Salesforce (for sales automation)
# SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
# SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret_here
# SALESFORCE_USERNAME=your_salesforce_username_here
# SALESFORCE_PASSWORD=your_salesforce_password_here

# HubSpot (alternative CRM)
# Get your key at: https://app.hubspot.com/settings/api-key
# HUBSPOT_API_KEY=your_hubspot_api_key_here

# Pipedrive (alternative CRM)
# PIPEDRIVE_API_TOKEN=your_pipedrive_token_here

# ============= SOCIAL MEDIA (Optional) =============

# Twitter/X (for social media automation)
# TWITTER_API_KEY=your_twitter_api_key_here
# TWITTER_API_SECRET=your_twitter_api_secret_here
# TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
# TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# LinkedIn (for professional social media)
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Facebook (for social media automation)
# FACEBOOK_APP_ID=your_facebook_app_id_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here
# FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# ============= ANALYTICS (Optional) =============

# Google Analytics (for marketing analytics)
# GOOGLE_ANALYTICS_ID=UA-your_analytics_id_here
# GOOGLE_ANALYTICS_KEY=your_analytics_key_here

# ============= CONTENT MANAGEMENT (Optional) =============

# WordPress (for blog publishing)
# WORDPRESS_URL=https://your-site.com
# WORDPRESS_USERNAME=your_wordpress_username_here
# WORDPRESS_PASSWORD=your_wordpress_app_password_here

# Medium (for blog publishing)
# MEDIUM_ACCESS_TOKEN=your_medium_token_here

# ============= MONITORING & LOGGING (Optional) =============

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry (for error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# Prometheus (for metrics)
# PROMETHEUS_PORT=9090

# ============= DEVELOPMENT OPTIONS (Optional) =============

# Debug Mode (true/false)
DEBUG=false

# Auto-reload on code changes (true/false)
AUTO_RELOAD=true

# Enable CORS (for development)
ENABLE_CORS=true

# Allowed Origins (comma-separated) — Do NOT use '*' in production
MURPHY_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# API Keys for authentication (comma-separated)
# In development mode (MURPHY_ENV=development), auth is optional.
# In staging/production, requests without a valid key are rejected (401).
# PRODUCTION NOTE: Do not put API keys in this file. Use a secrets manager:
#   Docker:  docker secret create murphy_api_key ./api_key.txt
#   K8s:     kubectl create secret generic murphy-secrets --from-literal=api-key=...
#   Vault:   vault kv put secret/murphy api_key=...
# MURPHY_API_KEYS=murphy_abc123,murphy_def456

# ============= MFM (Murphy Foundation Model) =============
# MFM_ENABLED=false                              # Enable MFM subsystem
# MFM_MODE=disabled                              # disabled | collecting | shadow | canary | production
# MFM_BASE_MODEL=microsoft/Phi-3-mini-4k-instruct  # Base model for fine-tuning
# MFM_CHECKPOINT_DIR=./checkpoints/mfm           # Where to store model checkpoints
# MFM_TRACE_DIR=./data/action_traces             # Where to store action traces
# MFM_RETRAIN_THRESHOLD=10000                    # Traces before auto-retrain
# MFM_SHADOW_MIN_ACCURACY=0.80                   # Min accuracy before retraining
# MFM_CANARY_TRAFFIC_PERCENT=10                  # % of traffic for canary deployment
# MFM_DEVICE=auto                                # cuda | cpu | auto

# ============= NOTES =============
#
# MINIMAL SETUP (Development):
# - Run: bash setup_and_start.sh — it auto-generates .env for you!
# - No API key required — the onboard LLM works out of the box
# - Everything else is optional
#
# RECOMMENDED SETUP (Development):
# - DEEPINFRA_API_KEY (optional, for enhanced LLM quality)
# - GITHUB_TOKEN (for repository integration)
# - DEBUG=true (for development)
#
# STAGING SETUP:
# - MURPHY_ENV=staging
# - MURPHY_API_KEYS=<generated keys>
# - MURPHY_CREDENTIAL_MASTER_KEY=<generated Fernet key>
# - MURPHY_REDIS_URL=redis://localhost:6379/0 (if running multi-worker)
# - DATABASE_URL (PostgreSQL)
# - DEBUG=false
#
# PRODUCTION SETUP:
# - All required keys from your integrations
# - MURPHY_ENV=production
# - MURPHY_API_KEYS — use secrets manager, NOT this file:
#     Docker: docker secret create murphy_api_key ./api_key.txt
#     K8s:    kubectl create secret generic murphy-secrets --from-literal=api-key=...
#     Vault:  vault kv put secret/murphy api_key=...
# - MURPHY_CREDENTIAL_MASTER_KEY — use secrets manager (not .env)
# - MURPHY_CORS_ORIGINS=<your allowed origins>
# - DATABASE_URL (PostgreSQL)
# - REDIS_URL / MURPHY_REDIS_URL (Redis — required for multi-worker)
# - MURPHY_JWT_SECRET (strong secret — use a secrets manager, not .env)
# - ENCRYPTION_KEY (strong secret — use a secrets manager, not .env)
# - DEBUG=false
# - Proper security headers
#
# ============= MATRIX INTEGRATION =============
#
# Required for the Murphy Matrix bridge (src/matrix_bridge/)
# Install matrix-nio with: pip install 'matrix-nio[e2e]'
#
# MATRIX_HOMESERVER_URL=https://matrix.example.com
# MATRIX_BOT_USER=@murphy:example.com
# MATRIX_BOT_TOKEN=
# MATRIX_BOT_PASSWORD=
# MATRIX_DEVICE_ID=
# MATRIX_E2E_ENABLED=false
# MATRIX_HOMESERVER_DOMAIN=example.com
# MATRIX_AUTO_CREATE_ROOMS=true
# MATRIX_SPACE_NAME=Murphy System
# MATRIX_ADMIN_USERS=@admin:example.com
#
# Webhook receiver
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8765
# WEBHOOK_SECRET_GITHUB=
# WEBHOOK_SECRET_STRIPE=
#
# Circuit breaker
# MATRIX_CB_THRESHOLD=5
# MATRIX_CB_TIMEOUT=60

# ============= BACKEND MODES (NEW — Beta Hardening) =============
#
# These variables control whether simulated/stub backends are permitted.
# In production/staging, stub modes are REJECTED at startup unless explicitly
# allowed.  In development/test, they default to allowed (with warnings).

# Database connector mode.
# (See DATABASE section above for MURPHY_DB_MODE, MURPHY_AUTO_MIGRATE,
#  MURPHY_DB_POOL_SIZE, and MURPHY_DB_MAX_OVERFLOW.)

# Matrix E2EE stub mode.
# true  = stub ciphertext allowed (with warning in responses)
# false = raise RuntimeError if matrix-nio SDK is absent (default in production)
# E2EE_STUB_ALLOWED=true

# Connection pool mode.
# simulated = in-memory stub pools (dev/test only; logs WARNING on every checkout)
# real      = httpx.AsyncClient HTTP pools (DB pooling requires SQLAlchemy)
# CRITICAL: MURPHY_POOL_MODE=simulated is rejected in production/staging.
# MURPHY_POOL_MODE=simulated

# Email delivery requirement.
# true  = a real backend (SendGrid or SMTP) is required; RuntimeError if absent
# false = fall back to MockEmailBackend with warning (default in development)
# Default is 'true' in production/staging.
# MURPHY_EMAIL_REQUIRED=false

# Enabled industrial protocols (comma-separated).
# For each listed protocol, the corresponding library must be importable.
# Raise ImportError at startup if any listed library is missing.
# Leave empty to allow all protocols to fall back to stub mode silently.
# Example: MURPHY_ENABLED_PROTOCOLS=bacnet,modbus,opcua
# MURPHY_ENABLED_PROTOCOLS=

# ============= LOGGING CONFIGURATION =============

# Log format override.
# text = human-readable (default in development/test)
# json = JSON lines parseable by ELK/Datadog/CloudWatch (default in production/staging)
# MURPHY_LOG_FORMAT=text

# ============= RESPONSE LIMITS =============

# Maximum response size in megabytes. Responses exceeding this limit return 413.
# Default: 10 MB
# MURPHY_MAX_RESPONSE_SIZE_MB=10

# ============= RUNTIME MODE =============
#
# Controls how Murphy System loads modules at startup.
#
# monolith — Load everything (current behavior). Safe, tested, heavy.
# tiered   — Load only what the team needs. Fast startup, lower memory.
#            Falls back to monolith automatically on failure.
#
# Default: monolith (opt-in to tiered once verified)
# MURPHY_RUNTIME_MODE=monolith

# Tiered runtime idle timeout (minutes).
# Domain packs with no activity for this long are automatically unloaded.
# Set to 0 to disable auto-unload.
# MURPHY_PACK_IDLE_TIMEOUT=30

# Tiered runtime fallback behavior when a pack fails to load.
# monolith  — Fall back to loading everything (safest)
# degraded  — Continue without the failed pack (logs error)
# strict    — Abort startup if any requested pack fails
# MURPHY_PACK_FALLBACK=monolith

# ============= FOUNDER / ADMIN ACCOUNT =============

# Founder account credentials — used to seed the initial admin account.
# All three must be set for the founder account to be created at startup.
# In development mode these are optional; in production they are REQUIRED.
MURPHY_FOUNDER_EMAIL=
MURPHY_FOUNDER_NAME=
MURPHY_FOUNDER_PASSWORD=

# ============= END CONFIGURATION =============
