# Murphy System 1.0 - Environment Configuration Template
#
# INSTRUCTIONS:
# 1. Run: bash setup_and_start.sh — it auto-generates .env for you.
#    You do NOT need to copy this file manually.
# 2. The onboard LLM works without any external API key.
#    Optionally add DEEPINFRA_API_KEY for enhanced quality (free at https://console.deepinfra.com).
# 3. In development mode, API authentication is disabled.
#    In staging and production modes, MURPHY_API_KEY must be configured.
#
# Copyright © 2020 Inoni Limited Liability Company
# Creator: Corey Post
# License: BSL 1.1

# ============= CORE CONFIGURATION (Required) =============

# Murphy System Version
MURPHY_VERSION=1.0.0

# Environment: development | staging | production
#
#   development — Authentication is DISABLED (local dev only, never deploy)
#   staging     — Authentication is ENABLED; verbose error messages allowed
#   production  — Authentication is ENABLED; minimal error exposure
#
# WARNING: deployment environments should always use 'staging' or 'production'.
# Deploying with MURPHY_ENV=development leaves ALL endpoints unauthenticated.
# NOTE: Use a secrets manager (Vault, AWS Secrets Manager, k8s Secrets) instead
# of this .env file for production credentials.
MURPHY_ENV=development

# Port number (default: 8000)
MURPHY_PORT=8000

# Persistence directory for JSON snapshots
MURPHY_PERSISTENCE_DIR=.murphy_persistence

# ============= LLM API KEYS (Optional — onboard LLM works without any key) =============

# LLM Provider selection (local, deepinfra, openai, or anthropic)
# Defaults to 'local' — the onboard LLM requires no external API key.
# Set to 'deepinfra', 'openai', or 'anthropic' once you add a key below.
MURPHY_LLM_PROVIDER=local

# DeepInfra (Recommended for enhanced quality - FREE tier available)
# Get your key at: https://console.deepinfra.com/keys
# DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# DeepInfra API key pool (comma-separated, for load balancing / rate-limit rotation)
# DEEPINFRA_API_KEYS=key1,key2,key3

# Aristotle deterministic engine (optional external API)
# ARISTOTLE_API_KEY=your_aristotle_api_key_here
# ARISTOTLE_API_URL=https://api.aristotle.example.com/v1/analyze

# Wulfrum validation engine (optional)
# WULFRUM_API_KEY=your_wulfrum_api_key_here
# WULFRUM_API_URL=https://api.wulfrum.example.com/v1/validate

# OpenAI (alternative LLM provider)
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (alternative LLM provider)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ============= DATABASE (Optional — SQLite auto-created if omitted) =============

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/murphy

# MySQL (alternative)
# DATABASE_URL=mysql://username:password@localhost:3306/murphy

# ============= CACHE (Optional — in-memory cache if omitted) =============

# Redis (recommended for multi-worker / production)
# REDIS_URL=redis://localhost:6379/0
# MURPHY_REDIS_URL=redis://localhost:6379/0

# ============= DOCKER COMPOSE CREDENTIALS (Required for `docker compose up`) =============

# PostgreSQL (compose container) — REQUIRED when running docker compose
# POSTGRES_PASSWORD must be set; compose will fail without it.
POSTGRES_PASSWORD=CHANGEME_generate_a_strong_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_generate_a_strong_password
# REDIS_PASSWORD=  # Optional but recommended for production

# ============= SECURITY (Auto-generated if not provided) =============

# Master credential encryption key — Fernet format
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in staging/production. In development, an ephemeral key is used.
# MURPHY_CREDENTIAL_MASTER_KEY=your_fernet_key_here

# API Key — required for staging/production
# All requests must include X-API-Key header, Authorization: Bearer, or ?api_key= query param.
# MURPHY_API_KEY=murphy_secret_key_here

# JWT Secret — used for session tokens
# MURPHY_JWT_SECRET=your-jwt-secret-here

# General encryption key
# ENCRYPTION_KEY=your-encryption-key-here

# ============= OAUTH / SOCIAL SIGN-IN (Optional) =============

# OAuth Redirect URI (shared across providers)
# MURPHY_OAUTH_REDIRECT_URI=https://murphy.systems/api/auth/callback

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# MURPHY_OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
# MURPHY_OAUTH_GOOGLE_SECRET=your_google_client_secret_here

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id_here
# GITHUB_CLIENT_SECRET=your_github_client_secret_here
# MURPHY_OAUTH_GITHUB_CLIENT_ID=your_github_client_id_here
# MURPHY_OAUTH_GITHUB_SECRET=your_github_client_secret_here

# Meta (Facebook/Instagram) OAuth
# META_CLIENT_ID=your_meta_app_id_here
# META_CLIENT_SECRET=your_meta_app_secret_here
# MURPHY_OAUTH_META_CLIENT_ID=your_meta_app_id_here
# MURPHY_OAUTH_META_SECRET=your_meta_app_secret_here

# LinkedIn OAuth
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Apple Sign-In
# APPLE_CLIENT_ID=your_apple_client_id_here
# APPLE_TEAM_ID=your_apple_team_id_here
# APPLE_KEY_ID=your_apple_key_id_here
# APPLE_PRIVATE_KEY_PATH=./config/apple_auth_key.p8

# ============= GITHUB INTEGRATION (Optional) =============

# GITHUB_TOKEN=ghp_your_github_token_here

# ============= PAYMENT PROCESSING (Optional) =============

# Stripe
# STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ============= COINBASE ADVANCED TRADE API (Trader Automation) =============

# COINBASE_API_KEY=your_coinbase_api_key_here
# COINBASE_API_SECRET=your_coinbase_api_secret_here
# COINBASE_PASSPHRASE=your_coinbase_passphrase_here
COINBASE_LIVE_MODE=false
COINBASE_SANDBOX_URL=https://api-public.sandbox.exchange.coinbase.com
COINBASE_PROD_URL=https://api.coinbase.com

# ============= MARKET DATA FEEDS (Optional — free tiers available) =============

# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
# FINNHUB_API_KEY=your_finnhub_api_key_here
# POLYGON_API_KEY=your_polygon_api_key_here
# NEWS_API_KEY=your_news_api_key_here
# FRED_API_KEY=your_fred_api_key_here

# ============= TRADING COMPLIANCE =============

# MURPHY_TRADING_PAPER_MODE=true
# MURPHY_MAX_POSITION_SIZE_PCT=2.0
# MURPHY_DAILY_LOSS_LIMIT_PCT=5.0
# MURPHY_COMPLIANCE_EMAIL=compliance@murphy.systems

# ============= EMAIL & MESSAGING (Optional) =============

# SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_key_here

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Twilio (SMS/Voice)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ============= CRM INTEGRATION (Optional) =============

# HubSpot
# HUBSPOT_API_KEY=your_hubspot_api_key_here

# Pipedrive
# PIPEDRIVE_API_TOKEN=your_pipedrive_token_here

# Salesforce
# SALESFORCE_CONSUMER_KEY=your_salesforce_consumer_key_here
# SALESFORCE_CONSUMER_SECRET=your_salesforce_consumer_secret_here

# ============= SOCIAL MEDIA (Optional) =============

# Twitter / X
# TWITTER_API_KEY=your_twitter_api_key_here
# TWITTER_API_SECRET=your_twitter_api_secret_here
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# LinkedIn Marketing API
# LINKEDIN_MARKETING_TOKEN=your_linkedin_marketing_token_here

# ============= ANALYTICS (Optional) =============

# GOOGLE_ANALYTICS_API_KEY=your_google_analytics_api_key_here
# MIXPANEL_TOKEN=your_mixpanel_token_here

# ============= CONTENT MANAGEMENT (Optional) =============

# WORDPRESS_API_URL=https://your-site.com/wp-json/wp/v2
# WORDPRESS_API_KEY=your_wordpress_api_key_here
# NOTION_API_KEY=secret_your_notion_key_here

# ============= MONITORING & LOGGING (Optional) =============

# SENTRY_DSN=https://your_sentry_dsn_here
# DATADOG_API_KEY=your_datadog_api_key_here
# PAGERDUTY_API_KEY=your_pagerduty_api_key_here
LOG_LEVEL=INFO

# ============= DEVELOPMENT OPTIONS (Optional) =============

DEBUG=false

# Auto-reload on file changes (development only)
AUTO_RELOAD=true

# CORS — comma-separated allowed origins
ENABLE_CORS=true
MURPHY_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# ============= MFM (Murphy Foundation Model) =============

# MFM_LEARNING_RATE=0.001
# MFM_BATCH_SIZE=32
# MFM_SEQUENCE_LENGTH=512
# MFM_NUM_LAYERS=6
# MFM_HIDDEN_DIM=256
# MFM_VOCAB_SIZE=32000
# MFM_CANARY_TRAFFIC_PERCENT=5
# MFM_DATA_DIR=./data/mfm
# MFM_CHECKPOINT_DIR=./checkpoints/mfm

# ============= MATRIX INTEGRATION (Optional) =============
#
# Required for the Murphy Matrix bridge (src/matrix_bridge/)

# MATRIX_HOMESERVER_URL=https://matrix.murphy.systems
# MATRIX_BOT_USER=@murphy-bot:murphy.systems
# MATRIX_BOT_PASSWORD=your_bot_password_here
# MATRIX_ACCESS_TOKEN=your_matrix_access_token_here
# MATRIX_ROOM_ID=!roomid:murphy.systems
# MATRIX_ADMIN_ROOM_ID=!adminroomid:murphy.systems
# MATRIX_ALERT_ROOM_ID=!alertroomid:murphy.systems
# MATRIX_WEBHOOK_SECRET=your_matrix_webhook_secret_here

# ============= BACKEND MODES (Beta Hardening) =============
#
# Switch individual subsystems between real and stub backends.
# "stub" → deterministic in-memory fakes (safe for CI and demo).
# "live" → connect to real databases/APIs (requires credentials above).

# MURPHY_DB_MODE=stub
# MURPHY_REDIS_MODE=stub
# MURPHY_EMAIL_MODE=stub
# MURPHY_PAYMENT_MODE=stub

# Protocol enablement — comma-separated list.
# MURPHY_ENABLED_PROTOCOLS=bacnet,modbus,opcua

# ============= LOGGING CONFIGURATION =============

# Log format: text (human-readable) or json (ELK/Datadog/CloudWatch)
# MURPHY_LOG_FORMAT=text

# ============= RESPONSE LIMITS =============

# Maximum response size in megabytes (default: 10 MB)
# MURPHY_MAX_RESPONSE_SIZE_MB=10

# ============= RUNTIME MODE =============
#
# monolith — Load everything (current behavior). Safe, tested, heavy.
# tiered   — Load only what the team needs. Fast startup, lower memory.
# MURPHY_RUNTIME_MODE=monolith
# MURPHY_PACK_IDLE_TIMEOUT=30
# MURPHY_PACK_FALLBACK=monolith

# ============= INTERNAL MAIL SERVER =============
#
# Set MURPHY_MAIL_ENABLED=true when using docker-mailserver in the compose stack.
MURPHY_MAIL_ENABLED=true
MURPHY_MAIL_INTERNAL=true
MURPHY_MAIL_DOMAIN=murphy.systems
MURPHY_MAIL_HOSTNAME=mail.murphy.systems

# Webmail (Roundcube) — accessible at http://<host>:8443
MURPHY_WEBMAIL_PORT=8443

# Mail server admin account
MAIL_ADMIN_EMAIL=cpost@murphy.systems
MAIL_ADMIN_PASSWORD=CHANGEME_generate_a_strong_password

# IMAP polling (for EmailConnector and Matrix bridge)
IMAP_HOST=murphy-mailserver
IMAP_PORT=993
IMAP_USER=cpost@murphy.systems
IMAP_PASSWORD=CHANGEME_same_as_mail_admin_password

# Roundcube session key (change to a random 24-char string in production)
ROUNDCUBE_DES_KEY=CHANGEME_random_24char_key_here

# ============= GRANTS, TAX CREDITS & FINANCING =============

# Inoni LLC Legal / Registration Identifiers
# INONI_SAM_UEI=
# INONI_CAGE_CODE=
# INONI_EIN=
# INONI_GRANTS_GOV_USERNAME=

# Grant session management
GRANT_MAX_SESSIONS_PER_ACCOUNT=10

# DSIRE Database Integration (State Incentive Lookup)
# GRANT_DSIRE_API_KEY=

# ============= NOTES =============
#
# MINIMAL SETUP (Development):
# - Run: bash setup_and_start.sh — it auto-generates .env for you!
# - No API key required — the onboard LLM works out of the box
# - Everything else is optional
#
# RECOMMENDED SETUP (Development):
# - DEEPINFRA_API_KEY (optional, for enhanced LLM quality)
# - GITHUB_TOKEN (for repository integration)
# - DEBUG=true (for development)
#
# STAGING SETUP:
# - MURPHY_ENV=staging
# - MURPHY_API_KEY=<generated key>
# - MURPHY_CREDENTIAL_MASTER_KEY=<generated Fernet key>
# - MURPHY_REDIS_URL=redis://localhost:6379/0 (if running multi-worker)
# - DATABASE_URL (PostgreSQL)
# - DEBUG=false
#
# PRODUCTION SETUP:
# - All required keys from your integrations
# - MURPHY_ENV=production
# - MURPHY_API_KEY — use secrets manager, NOT this file:
#     Docker: docker secret create murphy_api_key ./api_key.txt
#     K8s:    kubectl create secret generic murphy-secrets --from-literal=api-key=...
#     Vault:  vault kv put secret/murphy api_key=...
# - MURPHY_CREDENTIAL_MASTER_KEY — use secrets manager (not .env)
# - MURPHY_CORS_ORIGINS=<your allowed origins>
# - DATABASE_URL (PostgreSQL)
# - REDIS_URL / MURPHY_REDIS_URL (Redis — required for multi-worker)
# - MURPHY_JWT_SECRET (strong secret — use a secrets manager, not .env)
# - ENCRYPTION_KEY (strong secret — use a secrets manager, not .env)
# - DEBUG=false
# - Proper security headers
#
# See documentation/deployment/CONFIGURATION.md for full variable reference.