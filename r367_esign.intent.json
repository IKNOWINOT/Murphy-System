{
  "module": "r367_esign",
  "blocks": {
    "get_queue": {
      "intent_plain": "Look up a form_intake_queue row by id. Returns sqlite3.Row dict or None. READ-ONLY.",
      "inputs": {
        "con": "sqlite3.Connection",
        "qid": "int"
      },
      "outputs": {
        "return": "Row dict or None"
      },
      "side_effects": [
        "READ-ONLY: SELECT FROM form_intake_queue"
      ],
      "failure_modes": [
        "E_DEP_0023",
        "E_CODE_0001"
      ],
      "must_not": [
        "modify DB",
        "raise on missing id"
      ],
      "test_array": {
        "weak": [
          {
            "input_signature": "con_first",
            "input": [
              -1
            ],
            "expected_return": null
          }
        ],
        "good": [
          {
            "input_signature": "con_first",
            "input": [
              5
            ],
            "expected_truthy": true
          }
        ],
        "precise": [
          {
            "input_signature": "con_first",
            "input": [
              9
            ],
            "expected_truthy": true
          }
        ],
        "really_good": [
          {
            "input_signature": "con_first",
            "input": [
              999999
            ],
            "expected_return": null
          }
        ]
      }
    },
    "already_signed": {
      "intent_plain": "Return signature_log row if queue already signed, None otherwise. Idempotency check.",
      "inputs": {
        "con": "sqlite3.Connection",
        "queue_id": "int"
      },
      "outputs": {
        "return": "Row dict or None"
      },
      "side_effects": [
        "READ-ONLY: SELECT FROM signature_log"
      ],
      "failure_modes": [
        "E_DEP_0023",
        "E_DEP_0017"
      ],
      "must_not": [
        "modify DB",
        "raise on missing queue_id"
      ],
      "test_array": {
        "weak": [
          {
            "input_signature": "con_first",
            "input": [
              -1
            ],
            "expected_return": null
          }
        ],
        "good": [
          {
            "input_signature": "con_first",
            "input": [
              1
            ],
            "expected_truthy": true
          }
        ],
        "precise": [
          {
            "input_signature": "con_first",
            "input": [
              9
            ],
            "expected_truthy": true
          }
        ],
        "really_good": [
          {
            "input_signature": "con_first",
            "input": [
              5
            ],
            "expected_return": null
          }
        ]
      }
    }
  },
  "pipelines": {
    "_self_check": {
      "intent_plain": "Module loads + sign functions exist",
      "anchors": [
        "already_signed",
        "get_employee",
        "get_queue",
        "get_tenant",
        "retroactive"
      ],
      "pipeline_check": {
        "module_loadable": true
      }
    }
  }
}