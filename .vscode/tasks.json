{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Murphy: Start Server",
            "type": "shell",
            "command": "cd 'Murphy System/murphy_integrated' && ./start.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Murphy: Stop Server",
            "type": "shell",
            "command": "pkill -f murphy_system_1.0_runtime.py",
            "problemMatcher": []
        },
        {
            "label": "Murphy: Install Dependencies",
            "type": "shell",
            "command": "cd 'Murphy System/murphy_integrated' && pip install -r requirements_murphy_1.0.txt",
            "problemMatcher": []
        },
        {
            "label": "Murphy: Run Quick Demo",
            "type": "shell",
            "command": "cd 'Murphy System/murphy_integrated' && python demo_murphy.py --demo quick",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Murphy: Run Full Demo",
            "type": "shell",
            "command": "cd 'Murphy System/murphy_integrated' && python demo_murphy.py --demo full",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Murphy: Health Check",
            "type": "shell",
            "command": "curl http://localhost:6666/api/health",
            "problemMatcher": []
        },
        {
            "label": "Murphy: View API Docs",
            "type": "shell",
            "command": "open http://localhost:6666/docs || xdg-open http://localhost:6666/docs",
            "problemMatcher": []
        },
        {
            "label": "Murphy: Run Tests",
            "type": "shell",
            "command": "cd 'Murphy System/murphy_integrated' && pytest tests/ -v",
            "problemMatcher": []
        }
    ]
}
