[Unit]
Description=Murphy engagement-loop license verification (PCR-054h)
After=murphy-engagement-inbound.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/Murphy-System
ExecStart=/opt/Murphy-System/venv/bin/python3 /opt/Murphy-System/src/engagement_verify_cli.py --limit 100
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
