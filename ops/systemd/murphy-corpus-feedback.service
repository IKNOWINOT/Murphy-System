[Unit]
Description=Murphy engagement-loop corpus feedback (PCR-054m)
After=murphy-engagement-verify.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/Murphy-System
ExecStart=/opt/Murphy-System/venv/bin/python3 /opt/Murphy-System/src/corpus_feedback_cli.py --limit 100
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
